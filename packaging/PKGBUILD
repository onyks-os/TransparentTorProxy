# ══════════════════════════════════════════════════════════════════════
# TTP — Arch Linux PKGBUILD
# ══════════════════════════════════════════════════════════════════════
#
# This file tells makepkg how to build a native Arch Linux package
# (.pkg.tar.zst) from the TTP source code.
#
# Unlike .deb and .rpm, Arch uses a single-file format (PKGBUILD)
# that defines everything: metadata, dependencies, build steps, and
# file installation. The build is run via `makepkg` which reads this
# file, calls build() and package(), and produces the final archive.
#
# For AUR (Arch User Repository) submission, this file would be placed
# in its own git repo alongside a .SRCINFO file generated by
# `makepkg --printsrcinfo`.
#
# Usage (local build):
#   cd packaging && makepkg -si
#
# Usage (AUR):
#   Upload PKGBUILD + .SRCINFO to aur.archlinux.org
# ══════════════════════════════════════════════════════════════════════

# Define the package name as it will appear in the Arch package manager (pacman).
pkgname=ttp

# The version of the software. This should match the version in pyproject.toml.
pkgver=0.1.0

# The release number. If you update the PKGBUILD but the software version (0.1.0) 
# hasn't changed, you increment this to tell users to update the package.
pkgrel=1

# A short description of what the software does.
pkgdesc="A Linux CLI tool that transparently routes all system traffic through the Tor network"

# The target architecture. 'any' means it's Python/script-based and works on x86_64, ARM, etc.
arch=('any')

# The project's homepage or repository URL.
url="https://github.com/onyks-os/TransparentTorProxy"

# The license under which the software is released.
license=('MIT')

# Runtime dependencies. Pacman will ensure these are installed before TTP runs.
# Notice how Arch package names differ slightly from Debian (e.g., 'python-typer' instead of 'python3-typer').
depends=('python' 'python-typer' 'python-rich' 'python-stem' 'nftables' 'tor')

# Build dependencies. These are only needed temporarily while creating the package.
makedepends=('python-build' 'python-installer' 'python-wheel')

# Where to get the source code. 
# In a real Arch User Repository (AUR) package, this would be a GitHub release URL.
# Since this is a local build script, it points to the local directory (.).
source=("local-source::.")

# Checksums to verify source file integrity. 'SKIP' is used for local sources since they change during development.
md5sums=('SKIP')

# The build() function is run first. Its job is to compile the code.
build() {
    # Move into the source directory.
    cd "$srcdir/local-source"
    
    # Use standard Python tools to build a 'wheel' (.whl) package.
    # --no-isolation tells it to use the system's python-build dependencies (listed in makedepends)
    # rather than downloading them in a temporary virtual environment.
    python -m build --wheel --no-isolation
}

# The package() function is run next. Its job is to take the compiled files 
# and place them into a fake root directory ($pkgdir) exactly as they should appear on the real system.
package() {
    cd "$srcdir/local-source"
    
    # Use python-installer to extract the wheel built in the previous step
    # and place its contents (the Python code and the 'ttp' executable command) into $pkgdir.
    python -m installer --destdir="$pkgdir" dist/*.whl
    
    # Install the systemd service file.
    # install -D creates necessary parent directories. -m644 sets permissions (read/write for owner, read for others).
    # It copies the local ttp.service to the correct systemd directory inside the package.
    install -Dm644 packaging/ttp.service "$pkgdir/usr/lib/systemd/system/ttp.service"
    
    # Install the license file (required by Arch Linux standards for MIT).
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
