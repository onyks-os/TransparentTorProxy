# TTP Integration Test Environment (Fedora)
FROM fedora:41

ENV container docker

# Install systemd, python, tor, nftables, curl, iproute
RUN dnf update -y && dnf install -y \
    systemd \
    python3 python3-pip \
    nftables tor procps-ng curl iptables iproute \
    libpcap-devel \
    && dnf clean all

# Fedora uses systemd by default, but we should mask the same things
RUN systemctl mask systemd-udevd.service \
                   systemd-udevd-kernel.socket \
                   systemd-udevd-control.socket \
                   systemd-modules-load.service \
                   sys-kernel-debug.mount \
                   sys-kernel-tracing.mount
# Configure systemd-resolved with a public DNS server to prevent loopback DNS resolution failures inside the Docker network namespace
RUN mkdir -p /etc/systemd/resolved.conf.d && \
    echo -e "[Resolve]\nDNS=8.8.8.8" > /etc/systemd/resolved.conf.d/test-dns.conf
# Set up virtual environment
RUN python3 -m venv /venv
ENV PATH="/venv/bin:$PATH"

COPY . /app
WORKDIR /app

# Install TTP with dev dependencies, NSE, and pyroute2 (netlink route setup without /sys mount)
RUN pip install -e .[dev] && pip install network-sandbox-engine pyroute2

STOPSIGNAL SIGRTMIN+3

CMD ["/usr/lib/systemd/systemd"]
